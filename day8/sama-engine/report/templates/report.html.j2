<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAMA/PDPL Compliance Report — {{ report.ddl_source }}</title>
<style>
/* ── Reset & Base ───────────────────────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
     display:flex;min-height:100vh;background:#f1f5f9;color:#1e293b;font-size:14px;line-height:1.6}

/* ── Sidebar ────────────────────────────────────────────────────────── */
.sidebar{
  width:220px;min-height:100vh;background:#0f172a;color:#cbd5e1;
  display:flex;flex-direction:column;position:sticky;top:0;height:100vh;
  overflow-y:auto;flex-shrink:0;
}
.sidebar-logo{
  padding:1.5rem 1.25rem 1rem;border-bottom:1px solid #1e293b;
}
.sidebar-logo h2{font-size:.85rem;font-weight:700;color:#38bdf8;letter-spacing:.05em;text-transform:uppercase}
.sidebar-logo p{font-size:.7rem;color:#64748b;margin-top:.2rem}
.nav-section{padding:.75rem 1.25rem .25rem;font-size:.65rem;font-weight:700;text-transform:uppercase;
             letter-spacing:.1em;color:#475569}
.nav-link{
  display:block;padding:.45rem 1.25rem;color:#94a3b8;text-decoration:none;font-size:.8rem;
  border-left:2px solid transparent;transition:all .15s
}
.nav-link:hover,.nav-link.active{color:#f8fafc;border-left-color:#38bdf8;background:#1e293b}
.nav-badge{float:right;background:#1e293b;border-radius:.75rem;padding:.1rem .45rem;
           font-size:.65rem;font-weight:600}
.sidebar-meta{margin-top:auto;padding:1rem 1.25rem;border-top:1px solid #1e293b;
              font-size:.7rem;color:#475569}

/* ── Main content ────────────────────────────────────────────────────── */
.content{flex:1;min-width:0;padding:2rem 2.5rem;max-width:1100px}

/* ── Page header ─────────────────────────────────────────────────────── */
.page-header{display:flex;align-items:flex-start;gap:2rem;margin-bottom:2rem;
             padding-bottom:1.5rem;border-bottom:2px solid #e2e8f0}
.page-header-text h1{font-size:1.5rem;font-weight:700;color:#0f172a}
.page-header-text .meta{font-size:.8rem;color:#64748b;margin-top:.4rem;display:flex;flex-wrap:wrap;gap:.75rem}
.meta-pill{background:#f1f5f9;border:1px solid #e2e8f0;border-radius:.25rem;
           padding:.1rem .5rem;font-family:monospace}

/* ── Gauge ───────────────────────────────────────────────────────────── */
.gauge-wrap{text-align:center;flex-shrink:0}
.gauge-label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;
             color:#64748b;margin-top:.4rem}
.verdict-pass{color:#16a34a;font-weight:700}
.verdict-warn{color:#d97706;font-weight:700}
.verdict-fail{color:#dc2626;font-weight:700}

/* ── Section headers ─────────────────────────────────────────────────── */
.section{margin-bottom:2.5rem}
.section-title{font-size:1rem;font-weight:700;color:#0f172a;margin-bottom:1rem;
               padding-bottom:.5rem;border-bottom:2px solid #e2e8f0;display:flex;align-items:center;gap:.5rem}
.section-title .count-badge{background:#e2e8f0;color:#64748b;border-radius:.75rem;
                             padding:.1rem .55rem;font-size:.7rem;font-weight:600}

/* ── Metric cards ─────────────────────────────────────────────────────── */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin-bottom:2rem}
.card{background:#fff;border-radius:.75rem;padding:1.25rem 1rem;border:1px solid #e2e8f0;text-align:center;
      box-shadow:0 1px 3px rgba(0,0,0,.06)}
.card .val{font-size:2rem;font-weight:800;line-height:1.1}
.card .label{font-size:.7rem;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-top:.35rem}
.card.c-critical .val{color:#dc2626}
.card.c-high .val    {color:#d97706}
.card.c-medium .val  {color:#ca8a04}
.card.c-low .val     {color:#0891b2}
.card.c-pass .val    {color:#16a34a}
.card.c-neutral .val {color:#334155}

/* ── Badges ──────────────────────────────────────────────────────────── */
.badge{display:inline-block;border-radius:.25rem;padding:.15rem .5rem;
       font-size:.7rem;font-weight:700;letter-spacing:.04em}
.badge-CRITICAL{background:#fee2e2;color:#b91c1c;border:1px solid #fca5a5}
.badge-HIGH    {background:#ffedd5;color:#c2410c;border:1px solid #fdba74}
.badge-MEDIUM  {background:#fef9c3;color:#854d0e;border:1px solid #fde047}
.badge-LOW     {background:#dbeafe;color:#1d4ed8;border:1px solid #93c5fd}
.badge-INFO    {background:#dcfce7;color:#15803d;border:1px solid #86efac}
.badge-pass    {background:#dcfce7;color:#15803d;border:1px solid #86efac}
.badge-fail    {background:#fee2e2;color:#b91c1c;border:1px solid #fca5a5}
.badge-skip    {background:#f1f5f9;color:#64748b;border:1px solid #cbd5e1}
.tier-1{color:#dc2626;font-weight:700}
.tier-2{color:#d97706;font-weight:600}
.tier-3{color:#7c3aed;font-weight:600}
.tier-4{background:#fef2f2;color:#991b1b;font-weight:700;border-radius:.2rem;padding:0 .3rem}

/* ── Tables ───────────────────────────────────────────────────────────── */
table{width:100%;border-collapse:collapse;background:#fff;border-radius:.75rem;
      overflow:hidden;border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.06)}
th{background:#f8fafc;padding:.65rem 1rem;text-align:left;font-size:.7rem;
   text-transform:uppercase;letter-spacing:.06em;color:#64748b;border-bottom:1px solid #e2e8f0;
   white-space:nowrap}
td{padding:.65rem 1rem;border-bottom:1px solid #f1f5f9;font-size:.825rem;vertical-align:top}
tr:last-child td{border-bottom:none}
tr:hover td{background:#f8fafc}
.col-mono{font-family:monospace;font-size:.75rem}

/* ── Code blocks ─────────────────────────────────────────────────────── */
details.remediation{margin-top:.5rem}
details.remediation summary{cursor:pointer;font-size:.75rem;color:#0891b2;user-select:none}
details.remediation summary:hover{text-decoration:underline}
pre.sql{background:#0f172a;color:#7dd3fc;border-radius:.5rem;padding:.75rem 1rem;
        font-size:.72rem;white-space:pre-wrap;word-break:break-word;
        margin-top:.5rem;overflow-x:auto;border:1px solid #1e293b}

/* ── Table cards (per-table breakdown) ───────────────────────────────── */
.table-card{background:#fff;border-radius:.75rem;border:1px solid #e2e8f0;
            margin-bottom:1.25rem;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.table-card-header{
  background:#f8fafc;padding:.75rem 1.25rem;display:flex;align-items:center;
  gap:.75rem;border-bottom:1px solid #e2e8f0;cursor:pointer
}
.table-card-header h3{font-size:.9rem;font-weight:700;color:#0f172a;font-family:monospace}
.table-card-header .tc-stats{margin-left:auto;display:flex;gap:.5rem;align-items:center;font-size:.75rem;color:#64748b}
.table-card-body{padding:1rem 1.25rem}
.tc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.tc-section-title{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;
                  color:#64748b;margin-bottom:.5rem}
.pii-chip{display:inline-flex;align-items:center;gap:.35rem;background:#f1f5f9;border:1px solid #e2e8f0;
          border-radius:.375rem;padding:.2rem .5rem;font-size:.75rem;margin:.2rem .2rem 0 0}

/* ── Rule results ─────────────────────────────────────────────────────── */
.rule-row{display:flex;align-items:center;gap:.75rem;padding:.6rem 1rem;
          background:#fff;border:1px solid #e2e8f0;border-radius:.5rem;margin-bottom:.5rem}
.rule-id{font-family:monospace;font-size:.78rem;color:#0891b2;min-width:130px}
.rule-name{flex:1;font-size:.825rem;color:#334155}
.rule-count{font-size:.75rem;color:#64748b}

/* ── Regulation breakdown ────────────────────────────────────────────── */
.reg-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
.reg-card{background:#fff;border-radius:.75rem;border:1px solid #e2e8f0;padding:1.25rem;text-align:center}
.reg-card .reg-val{font-size:2.25rem;font-weight:800;color:#0f172a}
.reg-card .reg-label{font-size:.75rem;color:#64748b;font-weight:600;margin-top:.3rem}
.reg-card .reg-sub{font-size:.7rem;color:#94a3b8;margin-top:.15rem}

/* ── Print styles ─────────────────────────────────────────────────────── */
@media print{
  body{display:block;background:#fff;color:#000;font-size:11pt}
  .sidebar{display:none}
  .content{padding:0;max-width:100%}
  .page-header{page-break-after:avoid}
  .section{page-break-inside:avoid}
  .table-card{page-break-inside:avoid;box-shadow:none}
  table{box-shadow:none}
  pre.sql{background:#f8f8f8;color:#1e293b;border:1px solid #ccc}
  .cards{grid-template-columns:repeat(6,1fr)}
}
</style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <h2>SAMA / PDPL</h2>
    <p>Compliance Engine</p>
  </div>

  <span class="nav-section">Report</span>
  <a class="nav-link active" href="#overview">Overview</a>
  <a class="nav-link" href="#findings">
    Findings
    {% set total = report.all_findings | length %}
    {% if total %}<span class="nav-badge">{{ total }}</span>{% endif %}
  </a>
  <a class="nav-link" href="#tables">
    Tables
    <span class="nav-badge">{{ report.schema_summary.get('table_count', 0) }}</span>
  </a>
  <a class="nav-link" href="#rules">Rule Results</a>

  {% if report.tables %}
  <span class="nav-section">Tables</span>
  {% for t in report.tables %}
  <a class="nav-link" href="#tbl-{{ t.name }}" style="font-size:.75rem;padding:.3rem 1.25rem">
    {{ t.name }}
    {% if t.finding_count %}<span class="nav-badge" style="background:#7f1d1d;color:#fca5a5">{{ t.finding_count }}</span>{% endif %}
  </a>
  {% endfor %}
  {% endif %}

  <div class="sidebar-meta">
    <div>Dialect: <strong>{{ report.dialect.upper() }}</strong></div>
    <div style="margin-top:.25rem;word-break:break-all">{{ report.scan_timestamp[:19].replace('T',' ') }} UTC</div>
  </div>
</aside>

<!-- Main content -->
<main class="content">

  <!-- Page header -->
  <div class="page-header" id="overview">
    <div class="page-header-text" style="flex:1">
      <h1>SAMA &amp; PDPL Compliance Report</h1>
      <div class="meta">
        <span class="meta-pill">{{ report.dialect.upper() }}</span>
        <span class="meta-pill">{{ report.ddl_source }}</span>
        <span class="meta-pill">{{ report.scan_timestamp[:19].replace('T',' ') }} UTC</span>
      </div>
    </div>

    <!-- Score gauge -->
    {% set score = report.score | int %}
    {% set r = 54 %}
    {% set circ = 339.29 %}
    {% set arc  = (score / 100 * circ) | round(2) %}
    {% set gap  = (circ - arc) | round(2) %}
    {% if score >= 80 %}{% set gauge_color = "#16a34a" %}{% set verdict = "COMPLIANT" %}{% set verdict_cls = "verdict-pass" %}
    {% elif score >= 50 %}{% set gauge_color = "#d97706" %}{% set verdict = "NEEDS ATTENTION" %}{% set verdict_cls = "verdict-warn" %}
    {% else %}{% set gauge_color = "#dc2626" %}{% set verdict = "NON-COMPLIANT" %}{% set verdict_cls = "verdict-fail" %}
    {% endif %}
    <div class="gauge-wrap">
      <svg width="130" height="130" viewBox="0 0 130 130" role="img" aria-label="Compliance score {{ score }} out of 100">
        <circle cx="65" cy="65" r="{{ r }}" fill="none" stroke="#e2e8f0" stroke-width="10"/>
        <circle cx="65" cy="65" r="{{ r }}" fill="none"
                stroke="{{ gauge_color }}" stroke-width="10"
                stroke-linecap="round"
                stroke-dasharray="{{ arc }} {{ gap }}"
                transform="rotate(-90 65 65)"/>
        <text x="65" y="60" text-anchor="middle" font-size="22" font-weight="800" fill="{{ gauge_color }}" font-family="system-ui">{{ score }}</text>
        <text x="65" y="76" text-anchor="middle" font-size="10" fill="#94a3b8" font-family="system-ui">/100</text>
      </svg>
      <div class="gauge-label {{ verdict_cls }}">{{ verdict }}</div>
    </div>
  </div>

  <!-- Executive summary cards -->
  <div class="section">
    {% set sev = report.severity_summary() %}
    {% set reg = report.findings_by_regulation() %}
    <div class="cards">
      <div class="card c-neutral">
        <div class="val">{{ report.schema_summary.get('table_count', '?') }}</div>
        <div class="label">Tables</div>
      </div>
      <div class="card c-neutral">
        <div class="val">{{ report.schema_summary.get('sensitive_columns', 0) }}</div>
        <div class="label">PII Columns</div>
      </div>
      <div class="card c-neutral">
        <div class="val">{{ report.all_findings | length }}</div>
        <div class="label">Total Findings</div>
      </div>
      <div class="card c-critical">
        <div class="val">{{ sev.CRITICAL }}</div>
        <div class="label">Critical</div>
      </div>
      <div class="card c-high">
        <div class="val">{{ sev.HIGH }}</div>
        <div class="label">High</div>
      </div>
      <div class="card c-medium">
        <div class="val">{{ sev.MEDIUM }}</div>
        <div class="label">Medium</div>
      </div>
      <div class="card c-low">
        <div class="val">{{ sev.LOW }}</div>
        <div class="label">Low</div>
      </div>
    </div>

    <!-- Regulation breakdown -->
    <div class="reg-grid">
      <div class="reg-card">
        <div class="reg-val">{{ reg.SAMA }}</div>
        <div class="reg-label">SAMA Findings</div>
        <div class="reg-sub">Saudi Central Bank regulations</div>
      </div>
      <div class="reg-card">
        <div class="reg-val">{{ reg.PDPL }}</div>
        <div class="reg-label">PDPL Findings</div>
        <div class="reg-sub">Personal Data Protection Law</div>
      </div>
    </div>
  </div>

  <!-- Findings section -->
  <div class="section" id="findings">
    <div class="section-title">
      Findings
      <span class="count-badge">{{ report.all_findings | length }}</span>
    </div>

    {% set sorted_findings = report.all_findings | sort(attribute='severity.weight', reverse=True) %}
    {% if sorted_findings %}
    <table>
      <thead>
        <tr>
          <th>Severity</th>
          <th>Rule ID</th>
          <th>Table</th>
          <th>Column</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
      {% for f in sorted_findings %}
        <tr>
          <td><span class="badge badge-{{ f.severity.value }}">{{ f.severity.value }}</span></td>
          <td class="col-mono">{{ f.rule_id }}</td>
          <td class="col-mono">{{ f.table }}</td>
          <td class="col-mono">{{ f.column or '—' }}</td>
          <td>
            {{ f.message }}
            {% if f.remediation %}
            <details class="remediation">
              <summary>Show remediation SQL</summary>
              <pre class="sql">{{ f.remediation }}</pre>
            </details>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:.75rem;padding:1.5rem;text-align:center;color:#15803d;font-weight:600">
      All checks passed — no findings.
    </div>
    {% endif %}
  </div>

  <!-- Per-table breakdown -->
  <div class="section" id="tables">
    <div class="section-title">
      Table Breakdown
      <span class="count-badge">{{ report.schema_summary.get('table_count', 0) }}</span>
    </div>

    {% if report.tables %}
      {% for tbl in report.tables %}
      <div class="table-card" id="tbl-{{ tbl.name }}">
        <div class="table-card-header">
          <h3>{{ tbl.name }}</h3>
          {% if tbl.has_sensitive_data %}
          <span class="badge badge-HIGH" style="font-size:.65rem">SENSITIVE</span>
          {% else %}
          <span class="badge badge-pass" style="font-size:.65rem">CLEAN</span>
          {% endif %}
          <div class="tc-stats">
            <span>{{ tbl.column_count }} col{{ 's' if tbl.column_count != 1 }}</span>
            {% if tbl.sensitive_column_count %}
            <span style="color:#dc2626">{{ tbl.sensitive_column_count }} PII</span>
            {% endif %}
            {% if tbl.finding_count %}
            <span style="color:#dc2626">{{ tbl.finding_count }} finding{{ 's' if tbl.finding_count != 1 }}</span>
            {% endif %}
          </div>
        </div>
        <div class="table-card-body">
          <div class="tc-grid">
            <!-- Columns -->
            <div>
              <div class="tc-section-title">Columns</div>
              <table style="font-size:.75rem">
                <thead><tr><th>Name</th><th>Type</th><th style="text-align:center">PK</th><th style="text-align:center">Null</th></tr></thead>
                <tbody>
                {% for col in tbl.columns %}
                <tr>
                  <td class="col-mono">{{ col.name }}{% if col.is_primary_key %} <span style="color:#0891b2;font-size:.65rem">PK</span>{% endif %}</td>
                  <td class="col-mono" style="color:#64748b">{{ col.type }}</td>
                  <td style="text-align:center">{% if col.is_primary_key %}✓{% endif %}</td>
                  <td style="text-align:center;color:#94a3b8">{% if col.nullable %}✓{% endif %}</td>
                </tr>
                {% endfor %}
                </tbody>
              </table>
            </div>
            <!-- PII + findings -->
            <div>
              {% if tbl.pii_classifications %}
              <div class="tc-section-title">PII Classifications</div>
              <div style="margin-bottom:.75rem">
                {% for p in tbl.pii_classifications %}
                <div class="pii-chip">
                  <span class="col-mono">{{ p.column }}</span>
                  <span class="tier-{{ p.tier }}">Tier {{ p.tier }}</span>
                  <span style="color:#64748b">{{ p.label }}</span>
                </div>
                {% endfor %}
              </div>
              {% endif %}
              {% if tbl.findings %}
              <div class="tc-section-title" style="margin-top:.5rem">Findings</div>
              {% for f in tbl.findings %}
              <div style="display:flex;gap:.5rem;align-items:flex-start;margin-bottom:.35rem">
                <span class="badge badge-{{ f.severity }}" style="flex-shrink:0;margin-top:.1rem">{{ f.severity }}</span>
                <div>
                  <span class="col-mono" style="color:#0891b2">{{ f.rule_id }}</span>
                  <span style="color:#64748b;margin-left:.4rem">{{ f.message }}</span>
                </div>
              </div>
              {% endfor %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    {% else %}
    <p style="color:#64748b;font-style:italic">Table breakdown not available — run via CLI with schema data.</p>
    {% endif %}
  </div>

  <!-- Rule results -->
  <div class="section" id="rules">
    <div class="section-title">
      Rule Results
      <span class="count-badge">{{ report.rule_results | length }}</span>
    </div>
    {% for result in report.rule_results %}
    <div class="rule-row">
      <span class="rule-id">{{ result.rule_id }}</span>
      <span class="rule-name">{{ result.rule_name }}</span>
      {% if result.skipped %}
      <span class="badge badge-skip">SKIPPED</span>
      {% elif result.passed %}
      <span class="badge badge-pass">PASSED</span>
      {% else %}
      <span class="badge badge-fail">FAILED</span>
      {% endif %}
      <span class="rule-count">{{ result.findings | length }} finding{{ 's' if result.findings | length != 1 }}</span>
    </div>
    {% endfor %}
  </div>

</main>

<script>
// Highlight active sidebar link on scroll
const sections = document.querySelectorAll('[id]');
const navLinks  = document.querySelectorAll('.nav-link');
const observer  = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(l => l.classList.remove('active'));
      const link = document.querySelector(`.nav-link[href="#${e.target.id}"]`);
      if (link) link.classList.add('active');
    }
  });
}, { threshold: 0.3 });
sections.forEach(s => observer.observe(s));
</script>
</body>
</html>
