-- ┌──────────────────────────────────────────────────────────────────────────┐
-- │ [SAMA-INT-001] Add primary key → {{ table }}
-- │ Every table must have a PK for record uniqueness and audit referencing
-- └──────────────────────────────────────────────────────────────────────────┘
-- Step 1: Add surrogate PK column
ALTER TABLE {{ table }}
    ADD COLUMN IF NOT EXISTS id BIGSERIAL;

-- Step 2: Populate id for existing rows (idempotent)
DO $$
BEGIN
    IF EXISTS (
        SELECT 1 FROM {{ table }} WHERE id IS NULL LIMIT 1
    ) THEN
        -- Assign sequential IDs to existing rows
        WITH numbered AS (
            SELECT ctid, ROW_NUMBER() OVER () AS rn FROM {{ table }} WHERE id IS NULL
        )
        UPDATE {{ table }} t
           SET id = n.rn
          FROM numbered n
         WHERE t.ctid = n.ctid;
    END IF;
END
$$;

-- Step 3: Add NOT NULL + PK constraint
ALTER TABLE {{ table }}
    ALTER COLUMN id SET NOT NULL;

ALTER TABLE {{ table }}
    ADD CONSTRAINT pk_{{ table }} PRIMARY KEY (id);
