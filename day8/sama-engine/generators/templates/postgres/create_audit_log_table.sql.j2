-- ┌──────────────────────────────────────────────────────────────────────────┐
-- │ [SAMA-AUD-003] Create audit log table → {{ table }}_audit_log
-- │ SAMA CSF §3.3.5 — immutable before/after record for all DML operations
-- └──────────────────────────────────────────────────────────────────────────┘
CREATE TABLE IF NOT EXISTS {{ table }}_audit_log (
    audit_id       BIGSERIAL     PRIMARY KEY,
    record_id      BIGINT        NOT NULL,
    operation      VARCHAR(10)   NOT NULL
                   CHECK (operation IN ('INSERT', 'UPDATE', 'DELETE')),
    performed_at   TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
    performed_by   VARCHAR(255)  NOT NULL
                   DEFAULT current_setting('app.current_user', TRUE),
    source_ip      INET          NULL,
    correlation_id UUID          NULL DEFAULT gen_random_uuid(),
    old_values     JSONB         NULL,
    new_values     JSONB         NULL
);

-- Indexes for efficient audit queries
CREATE INDEX IF NOT EXISTS idx_{{ table }}_audit_record
    ON {{ table }}_audit_log (record_id);
CREATE INDEX IF NOT EXISTS idx_{{ table }}_audit_performed
    ON {{ table }}_audit_log (performed_at DESC);
CREATE INDEX IF NOT EXISTS idx_{{ table }}_audit_operation
    ON {{ table }}_audit_log (operation);

-- Trigger function
CREATE OR REPLACE FUNCTION fn_{{ table }}_audit()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER
SET search_path = public AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        INSERT INTO {{ table }}_audit_log
            (record_id, operation, performed_by, source_ip, correlation_id, new_values)
        VALUES (
            NEW.{{ pk_col }},
            'INSERT',
            current_setting('app.current_user', TRUE),
            inet_client_addr(),
            gen_random_uuid(),
            to_jsonb(NEW)
        );
        RETURN NEW;

    ELSIF TG_OP = 'UPDATE' THEN
        INSERT INTO {{ table }}_audit_log
            (record_id, operation, performed_by, source_ip, correlation_id, old_values, new_values)
        VALUES (
            NEW.{{ pk_col }},
            'UPDATE',
            current_setting('app.current_user', TRUE),
            inet_client_addr(),
            gen_random_uuid(),
            to_jsonb(OLD),
            to_jsonb(NEW)
        );
        RETURN NEW;

    ELSIF TG_OP = 'DELETE' THEN
        INSERT INTO {{ table }}_audit_log
            (record_id, operation, performed_by, source_ip, correlation_id, old_values)
        VALUES (
            OLD.{{ pk_col }},
            'DELETE',
            current_setting('app.current_user', TRUE),
            inet_client_addr(),
            gen_random_uuid(),
            to_jsonb(OLD)
        );
        RETURN OLD;
    END IF;
    RETURN NULL;
END;
$$;

DROP TRIGGER IF EXISTS trg_{{ table }}_audit ON {{ table }};
CREATE TRIGGER trg_{{ table }}_audit
    AFTER INSERT OR UPDATE OR DELETE ON {{ table }}
    FOR EACH ROW EXECUTE FUNCTION fn_{{ table }}_audit();

