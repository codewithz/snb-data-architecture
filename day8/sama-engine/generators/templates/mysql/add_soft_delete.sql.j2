-- ┌──────────────────────────────────────────────────────────────────────────┐
-- │ [SAMA-AUD-002] Add soft-delete columns → {{ table }}
-- │ SAMA CSF §3.3.7 — logical deletion preserves audit trail
-- └──────────────────────────────────────────────────────────────────────────┘
ALTER TABLE {{ table }}
    ADD COLUMN IF NOT EXISTS is_deleted  TINYINT(1)   NOT NULL DEFAULT 0,
    ADD COLUMN IF NOT EXISTS deleted_at  DATETIME     NULL,
    ADD COLUMN IF NOT EXISTS deleted_by  VARCHAR(255) NULL;

CREATE INDEX IF NOT EXISTS idx_{{ table }}_is_deleted ON {{ table }} (is_deleted);

-- Usage: instead of DELETE, use:
-- UPDATE {{ table }}
--   SET is_deleted = 1, deleted_at = NOW(), deleted_by = @current_user
--   WHERE id = ?;
