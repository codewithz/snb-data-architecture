-- ============================================================
-- SAMA Audit Trail — Cross-Table Correlation Trace View (MySQL)
-- ============================================================

-- ── Unified audit view ─────────────────────────────────────
CREATE OR REPLACE VIEW v_audit_trace AS
{% for table in audited_tables %}
SELECT
    '{{ table }}'           AS source_table,
    audit_id,
    record_id,
    operation,
    performed_by,
    performed_at,
    application_id,
    source_ip,
    correlation_id,
    session_id,
    old_values,
    new_values
FROM {{ table }}_audit_log
{% if not loop.last %}UNION ALL
{% endif %}
{% endfor %}
ORDER BY performed_at;

-- ── Usage ─────────────────────────────────────────────────
-- Trace a single business transaction:
--   SELECT * FROM v_audit_trace
--    WHERE correlation_id = 'your-uuid-here'
--    ORDER BY performed_at;
--
-- All changes by a specific user in the last 24 hours:
--   SELECT * FROM v_audit_trace
--    WHERE performed_by = 'ali@example.com'
--      AND performed_at > DATE_SUB(NOW(), INTERVAL 24 HOUR)
--    ORDER BY performed_at DESC;
